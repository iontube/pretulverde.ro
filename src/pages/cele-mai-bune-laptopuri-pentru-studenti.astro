  { name: "Cele mai bune laptopuri pentru studenti", url: "/cele-mai-bune-laptopuri-pentru-studenti/" }
];

const faq = [
  { question: "cat costa un laptop bun pentru student acum?", answer: "Un laptop bun pentru student, care să ofere un echilibru optim între performanță și preț, costă în jur de 2500-4000 lei. În acest interval poți găsi modele fiabile cu procesoare Intel Core i5/AMD Ryzen 5, 8-16GB RAM și SSD de minim 256GB." },
  { question: "ce e mai bun laptop lenovo sau hp pentru facultate?", answer: "Atât Lenovo (seria IdeaPad 5) cât și HP (seria Pavilion 15) oferă modele excelente pentru studenți. Lenovo excelează la confortul tastaturii și autonomia bateriei, în timp ce HP se remarcă prin designul mai modern și, uneori, performanță grafică ușor superioară." },
  { question: "cat rezista un laptop bun pentru student?", answer: "Un laptop bun pentru student, ales cu specificațiile potrivite (i5/Ryzen 5, 16GB RAM, SSD), ar trebui să reziste fără probleme cel puțin 3-4 ani în condiții de utilizare normală pentru studiu. Modelele mai premium pot ține chiar și mai mult." },
  { question: "ce procesor sa aleg pentru laptopul de student?", answer: "Pentru un laptop de student, un procesor Intel Core i5 sau AMD Ryzen 5 este ideal. Acestea oferă un echilibru excelent între performanță și consum de energie, fiind potrivite pentru majoritatea sarcinilor academice și uz general." },
  { question: "de ce laptopul meu de student e prea lent?", answer: "Laptopul tău de student poate fi lent din mai multe motive: prea puțin RAM (minim 8GB, ideal 16GB), un hard disk vechi (HDD) în loc de SSD, prea multe programe care rulează în fundal sau un procesor prea vechi/slab pentru sarcinile pe care le desfășori." },
  { question: "cand merita sa cumpar laptop nou pentru facultate?", answer: "Cel mai bun moment să cumperi un laptop nou pentru facultate este în perioadele de reduceri mai puțin așteptate sau când modelele anterioare intră la promoții după lansarea noilor generații. Evită să cumperi imediat după lansare când prețurile sunt cele mai mari." },
  { question: "ce laptop sa iau pentru programare student?", answer: "Pentru programare, un laptop cu cel puțin 16GB RAM și un procesor Intel Core i5/i7 sau AMD Ryzen 5/7 este recomandat. Un SSD rapid (minim 512GB) ajută la viteza de compilare și rularea mediilor de dezvoltare (IDE-uri)." },
  { question: "este bun un laptop refurbished pentru student?", answer: "Da, un laptop refurbished de la branduri premium (Dell Latitude, HP EliteBook, Lenovo ThinkPad) poate fi o opțiune excelentă pentru studenți, oferind calitate de construcție superioară și fiabilitate la un preț mai mic, adesea cu garanție de 1-2 ani." }
];

const toc = [
  { title: "Cel mai bun laptop pentru tine AGUM, si la ce pret sa te astepti", id: "cel-mai-bun-laptop-pentru-tine-agum-si-la-ce-pret-sa-te-astepti" },
  { title: "Ce laptop sa iei ACUM: 4-5 modele ce merita atentia", id: "ce-laptop-sa-iei-acum-4-5-modele-ce-merita-atentia" },
  { title: "Ce sa cauti la un laptop pentru facultate (fara sa te prostesti)", id: "ce-sa-cauti-la-un-laptop-pentru-facultate-fara-sa-te-prostesti" },
  { title: "Lenovo IdeaPad 5 vs. HP Pavilion 15: Care merită banii TAI?", id: "lenovo-ideapad-5-vs-hp-pavilion-15-care-merita-banii-tai" },
  { title: "Greșeli comune de EVITAT când cumperi un laptop pentru școală", id: "greseli-comune-de-evitat-cand-cumperi-un-laptop-pentru-scoala" },
