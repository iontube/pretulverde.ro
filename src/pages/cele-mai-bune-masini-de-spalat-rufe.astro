};

const faq = [
  { question: "cat costa o masina de spalat rufe buna?", answer: "O masina de spalat rufe buna, cu specificatii decente si motor Inverter, costa intre 2000 si 2800 lei. Modelele mai ieftine, sub 1800 lei, sunt optiuni de baza, potrivite pentru bugete limitate." },
  { question: "ce e mai bun samsung sau lg la masini de spalat?", answer: "Ambele branduri sunt excelente. Samsung exceleaza la design si functii inovatoare, iar LG la durabilitatea motorului si protectia hainelor. Pentru un echilibru, Samsung WW90T4543TE/LE e o alegere buna, iar pentru protectia hainelor, LG F4WV708S1 e superior." },
  { question: "cat rezista in medie o masina de spalat rufe?", answer: "O masina de spalat rufe de calitate, cu motor Inverter, poate rezista intre 10 si 15 ani daca este intretinuta corect. Modelele mai ieftine, cu motoare cu perii, pot dura intre 5 si 8 ani." },
  { question: "ce masina de spalat sa aleg pentru o familie de 4 persoane?", answer: "Pentru o familie de 4 persoane, recomandam o masina de spalat cu o capacitate de minim 8 kg. Modele precum Samsung WW90T4543TE/LE (9 kg) sau LG F4WV708S1 (8 kg) sunt optiuni potrivite si fiabile." },
  { question: "de ce masina mea de spalat face zgomot mare la centrifugare?", answer: "Zgomotul mare la centrifugare poate fi cauzat de o incarcatura neuniforma a rufelor, de faptul ca masina nu este nivelata corect pe podea, sau de uzura motorului/rulmentilor. Verifica nivelarea si distribuie uniform rufele." },
  { question: "ce viteza de centrifugare este ideala?", answer: "Viteza de centrifugare ideala pentru majoritatea utilizatorilor este de 1400 rpm. Aceasta stoarce rufele suficient de bine pentru o uscare rapida, fara a uza excesiv masina sau hainele." },
  { question: "cand merita sa cumperi o masina de spalat rufe?", answer: "Cel mai bun moment pentru a cumpara o masina de spalat rufe este in perioadele cu reduceri majore, cum ar fi Black Friday (noiembrie) sau reducerile de sezon. Asteptarea poate aduce economii de cateva sute de lei." },
  { question: "masinile de spalat cu functia de abur sunt mai bune?", answer: "Functia de abur poate ajuta la igienizarea rufelor si la reducerea sifonarii, dar nu este esentiala. O masina de spalat cu programe de baza de calitate si motor Inverter, chiar si fara abur, poate fi o alegere mai buna si mai accesibila." }
];

const toc = [
  { title: "Ce masina de spalat sa iei acum si la ce pret, sincer", id: "ce-masina-de-spalat-sa-iei-acum-si-la-ce-pret-sincer" },
  { title: "Top 4 masini de spalat rufe: Ce merita cumparat acum si de ce", id: "top-4-masini-de-spalat-rufe-ce-merita-cumparat-acum-si-de-ce" },
  { title: "Cum sa alegi masina de spalat potrivita: specificatii care conteaza, nu vrajeli de marketing", id: "cum-sa-alegi-masina-de-spalat-potrivita-specificatii-care-conteaza-nu-vrajeli-de-marketing" },
  { title: "Samsung vs. LG: Care face treaba mai buna pentru tine?", id: "samsung-vs-lg-care-face-treaba-mai-buna-pentru-tine" },
  { title: "Greseli frecvente la cumpararea unei masini de spalat si cum sa le eviti", id: "greseli-frecvente-la-cumpararea-unei-masini-de-spalat-si-cum-sa-le-eviti" },
