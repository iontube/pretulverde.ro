  { title: "Cum sa alegi cele mai bune masini de tuns iarba pentru tine: ghidul omului practic", id: "cum-sa-alegi-cele-mai-bune-masini-de-tuns-iarba-pentru-tine-ghidul-omului-practic" },
  { title: "Electrica vs. Benzina vs. Acumulator: Care e diferenta la cele mai bune masini de tuns iarba?", id: "electrica-vs-benzina-vs-acumulator-care-e-diferenta-la-cele-mai-bune-masini-de-tuns-iarba" },
  { title: "Greseli frecvente la alegerea si utilizarea celor mai bune masini de tuns iarba", id: "greseli-frecvente-la-alegerea-si-utilizarea-celor-mai-bune-masini-de-tuns-iarba" },
