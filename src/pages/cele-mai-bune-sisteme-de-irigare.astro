---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import keywordsData from '../../keywords.json';

export const frontmatter = {
  title: "Cele mai bune sisteme de irigare",
  excerpt: "Daca vrei cele mai bune sisteme de irigare pentru gradina ta, fara batai de cap, mergi pe un sistem automatizat cu senzori de umiditate si un controller programabil. Pentru suprafete mici si mijlocii, sistemele de la Gardena sunt o optiune sigura, iar pentru bugete mai generoase, Hunter sau Rain Bird ofera solutii profesionale. Pana la urma, totul se rezuma la nevoile specifice ale culturilor tale si la timpul pe care il ai la dispozitie.",
  image: "/images/articles/cele-mai-bune-sisteme-de-irigare.webp",
  category: "Casa si Gradina",
  categorySlug: "casa-gradina",
  date: "2025-04-20T11:00:00.000Z",
  modifiedDate: "2026-02-27T08:41:33.490Z",
  author: "Elena Marin",
  authorRole: "Expert Casa si Gradina",
  authorBio: "Elena are experienta practica cu scule electrice, mobilier si echipamente de gradina. Testeaza produse si ofera recomandari bazate pe durabilitate, pret si usurinta de utilizare."
};

const breadcrumbs = [
  { name: "Acasa", url: "/" },
  { name: "Casa si Gradina", url: "/casa-gradina/" },
  { name: "Cele mai bune sisteme de irigare", url: "/cele-mai-bune-sisteme-de-irigare/" }
];

const faq = [
  { question: "care e diferenta intre un sistem de irigare prin picurare si unul cu aspersoare", answer: "Sistemul prin picurare duce apa direct la radacina plantei, minimizand pierderile prin evaporare si prevenind aparitia bolilor fungice pe frunze. Aspersoarele stropesc uniform o zona mai larga, fiind ideale pentru gazon. Alegerea depinde de ce vrei sa uzi: picurare pentru legume, flori, arbori; aspersoare pentru gazon." },
  { question: "cat costa un sistem de irigare automatizat pentru o gradina de 100 mp", answer: "Pentru o gradina de 100 mp, un sistem automatizat cu controller Wi-Fi, senzori de ploaie si umiditate de la producatori ca Gardena te-ar putea costa intre 800 si 1500 lei. Aceasta suma include controllerul, electrovalvele si senzorii, dar poate varia in functie de numarul de zone de irigare si complexitatea sistemului." },
  { question: "merita sa cumpar un sistem de irigare cu senzori", answer: "Da, merita pe deplin. Senzorii de ploaie si umiditate optimizeaza consumul de apa, oprind irigarea cand este inutila sau cand solul este deja suficient de umed. Un sistem cu senzori te poate ajuta sa economisesti pana la 30-40% din apa utilizata, protejand in acelasi timp plantele de udarea excesiva." },
  { question: "ce marca de sistem de irigare e mai buna", answer: "Pentru uz casnic, Gardena ofera un echilibru excelent intre usurinta in utilizare, functii smart si pret. Pentru solutii mai profesionale si durabile, Hunter si Rain Bird sunt lideri de piata, dar vin la un pret mai ridicat si cu o complexitate mai mare in instalare si configurare." },
  { question: "cum se monteaza un sistem de irigare prin picurare", answer: "Montajul implică conectarea furtunului principal la sursa de apă (robinet), apoi adăugarea picurătorilor la distanțe potrivite pentru plantele tale sau folosirea furtunului cu picurători integrați. Asigură-te că furtunul este bine fixat și că presiunea apei este adecvată." },
  { question: "de ce nu mai functioneaza aspersorul de la sistemul de irigare", answer: "Cauzele pot fi multiple: filtru înfundat, duză blocată cu calcar sau resturi, presiune insuficientă în sistem, o problemă cu electrovalva sau o defecțiune internă a aspersorului. Verifică întâi elementele simple, precum filtrele și duzele." },
  { question: "unde gasesc piese de schimb pentru sisteme de irigare", answer: "Piese de schimb precum duze, picurători, garnituri, electrovalve și controllere pot fi găsite în magazinele mari de bricolaj (Dedeman, Leroy Merlin, Hornbach), în magazine specializate pe instalații de irigații sau online pe platforme precum eMAG. Producătorii importanți au și rețele de distribuitori autorizați." },
  { question: "cat de des trebuie sa ud gradina cu sistem de irigare", answer: "Frecvența udării depinde de tipul culturilor, de vreme și de tipul solului. Un sistem automatizat cu senzori de umiditate va face asta pentru tine. În general, legumele și florile tinere necesită udare mai frecventă (zilnic sau o dată la două zile), în timp ce plantele mature și gazonul pot fi udate mai rar, dar mai abundent (de 2-3 ori pe săptămână)." }
];

const toc = [
  { title: "Ce sa alegi: Gata cu stropitul manual, vine irigarea inteligenta!", id: "ce-sa-alegi-gata-cu-stropitul-manual-vine-irigarea-inteligenta" },
  { title: "Top recomandari: Sisteme de irigare sub lupa, cu preturi si peripeții", id: "top-recomandari-sisteme-de-irigare-sub-lupa-cu-preturi-si-peripetii" },
  { title: "Cum alegi cele mai bune sisteme de irigare pentru nevoile tale", id: "cum-alegi-cele-mai-bune-sisteme-de-irigare-pentru-nevoile-tale" },
  { title: "Comparatie: Gardena vs. Hunter - Batalia sistemelor pentru gradina", id: "comparatie-gardena-vs-hunter---batalia-sistemelor-pentru-gradina" },
  { title: "Cele mai frecvente greseli si sfaturi de meserias", id: "cele-mai-frecvente-greseli-si-sfaturi-de-meserias" },
  { title: "Verdict pe buget: Cele mai bune sisteme de irigare pentru buzunare diferite", id: "verdict-pe-buget-cele-mai-bune-sisteme-de-irigare-pentru-buzunare-diferite" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

<Layout
  title="Cele mai bune sisteme de irigare - PretulVerde"
  description="Daca vrei cele mai bune sisteme de irigare pentru gradina ta, fara batai de cap, mergi pe un sistem automatizat cu senzori de umiditate si un controller programabil. Pentru suprafete mici si mijlocii, sistemele de la Gardena sunt o optiune sigura, iar pentru bugete mai generoase, Hunter sau Rain Bird ofera solutii profesionale. Pana la urma, totul se rezuma la nevoile specifice ale culturilor tale si la timpul pe care il ai la dispozitie."
  image="/images/articles/cele-mai-bune-sisteme-de-irigare.webp"
  type="article"
  publishedTime="2025-04-20T11:00:00.000Z"
  modifiedTime="2026-02-27T08:41:33.490Z"
  author="Elena Marin"
  faq={faq}
  breadcrumbs={breadcrumbs}
>
  <article class="article-page">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs" aria-label="Breadcrumbs">
