      </ol>
    </nav>

    <!-- Title -->
    <h1 class="article-page-title">Cele mai bune sisteme de irigare</h1>

    <!-- Meta -->
    <div class="article-page-meta">
      <span>Elena Marin</span>
      <span>&middot;</span>
      <span>Publicat: 20 aprilie 2025</span>
      <span>&middot;</span>
      <span>Actualizat: 27 februarie 2026</span>
    </div>

    <!-- Featured Image -->
    <img src="/images/articles/cele-mai-bune-sisteme-de-irigare.webp" alt="Cele mai bune sisteme de irigare" class="article-page-image" width="800" height="600" loading="eager">

    <!-- Two-column layout: content + TOC sidebar on RIGHT -->
    <div class="article-layout">
      <div>
        <!-- Mobile TOC (expandable) -->
        <div class="toc-mobile" id="toc-mobile">
          <button class="toc-mobile-toggle" onclick="this.parentElement.classList.toggle('open')">
            Cuprins
            <span class="toc-chevron">&#9660;</span>
