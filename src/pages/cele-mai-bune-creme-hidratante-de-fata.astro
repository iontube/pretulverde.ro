---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import keywordsData from '../../keywords.json';

export const frontmatter = {
  title: "Cele mai bune creme hidratante de fata",
  excerpt: "Daca vrei o crema hidratanta de fata buna, fara batai de cap, ia <strong>La Roche-Posay Toleriane Sensitive Creme</strong>. E cam 70-80 RON pe eMAG si e perfecta pentru pielea sensibila, calmeaza si hidrateaza pe bune. E o alegere sigura pentru majoritatea, indiferent de tipul pielii, pentru ca nu are parfum si e hipoalergenica.",
  image: "/images/articles/cele-mai-bune-creme-hidratante-de-fata.webp",
  category: "Sanatate si Frumusete",
  categorySlug: "sanatate-frumusete",
  date: "2025-09-05T14:00:00.000Z",
  modifiedDate: "2026-02-02T12:00:00.000Z",
  author: "Cristina Radu",
  authorRole: "Specialist Sanatate si Frumusete",
  authorBio: "Cristina analizeaza cosmetice, suplimente si produse de ingrijire personala. Compara ingrediente, preturi si rezultate reale pentru a te ajuta sa faci alegerile potrivite."
};

const faq = [
  { question: "cat costa o crema hidratanta de fata buna?", answer: "O crema hidratanta de fata buna, eficienta si sigura pentru majoritatea tipurilor de piele, costa in jur de 60-100 RON. Branduri precum Cerave, La Roche-Posay sau Vichy ofera produse excelente in acest interval de pret, cu formule bazate pe ingrediente benefice precum acid hialuronic si ceramide." },
  { question: "care e cea mai buna crema hidratanta de fata pentru piele sensibila?", answer: "Cea mai buna crema hidratanta de fata pentru piele sensibila este La Roche-Posay Toleriane Sensitive Creme, care costa aproximativ 70-80 RON. Formula sa hipoalergenica, fara parfum si fara alcool, calmeaza eficient iritatiile si ofera hidratare fara a provoca reactii adverse." },
  { question: "ce crema hidratanta de fata sa aleg pentru ten uscat?", answer: "Pentru ten uscat, recomandam Cerave Moisturising Cream (60-80 RON pentru 340g). Contine ceramide si acid hialuronic, esentiale pentru refacerea barierei pielii si hidratare profunda. O crema mai bogata, cu unt de shea, poate fi o optiune buna pentru timpul rece." },
  { question: "ce crema hidratanta de fata e buna pentru ten gras?", answer: "Pentru ten gras, cauta creme cu textura de gel sau lotiune, \"oil-free\" si \"non-comedogenic\", precum Vichy Minéral 89 (90-110 RON). Aceasta ofera hidratare usoara, fara a incarca tenul, si se absoarbe rapid. Niacinamida este un ingredient benefic pentru reglarea sebumului." },
  { question: "ce e mai bun La Roche-Posay sau Cerave pentru fata?", answer: "Ambele branduri sunt excelente. La Roche-Posay Toleriane Sensitive Creme (70-80 RON) e ideala pentru pielea sensibila si iritata. Cerave Moisturising Cream (60-80 RON/340g) ofera o hidratare mai \"nutritiva\" datorita ceramidelor si e mai economica pe termen lung." },
  { question: "de ce e importanta crema hidratanta de fata?", answer: "Crema hidratanta de fata mentine pielea hidratata, previne pierderea apei, intareste bariera naturala a pielii si o protejeaza de factorii de mediu. O piele bine hidratata arata mai fina, mai elastica si mai tanara, prevenind aparitia prematura a ridurilor." },
  { question: "cand merita sa cumperi o crema hidratanta de fata mai scumpa?", answer: "Merita sa cumperi o crema mai scumpa daca are ingrediente active specifice pentru problemele tale (ex: retinol pentru anti-aging, vitamina C concentrata pentru pete) sau daca ai nevoie de o textura foarte particulara pe care brandurile mai accesibile nu o ofera. Altfel, cremele de farmacie la 70-100 RON sunt de obicei suficiente." },
  { question: "cum aleg crema hidratanta daca am ten mixt?", answer: "Pentru ten mixt, cauta o crema \"echilibrata\": usoara pe frunte si nas (zona T), dar suficient de hidratanta pe obraji. Vichy Minéral 89 (90-110 RON) sau Cerave Moisturising Cream aplicata in cantitate mica pot fi optiuni bune. Uneori, aplicarea a doua creme diferite pe zone diferite poate fi solutia." }
];

const toc = [
  { title: "Ce crema hidratanta de fata sa alegi ACUM si la ce preturi", id: "ce-crema-hidratanta-de-fata-sa-alegi-acum-si-la-ce-preturi" },
  { title: "Top 4 creme hidratante de fata - Alegeri concrete cu preturi si pareri", id: "top-4-creme-hidratante-de-fata---alegeri-concrete-cu-preturi-si-pareri" },
  { title: "Ce criterii conteaza cu adevarat la o crema hidratanta de fata (si ce e doar marketing)", id: "ce-criterii-conteaza-cu-adevarat-la-o-crema-hidratanta-de-fata-si-ce-e-doar-marketing" },
  { title: "Comparatie directa: Care crema hidratanta e regele pentru bugetul tau?", id: "comparatie-directa-care-crema-hidratanta-e-regele-pentru-bugetul-tau" },
  { title: "Cum sa nu dai de gard cand cumperi o crema hidratanta de fata: greseli si tips", id: "cum-sa-nu-dai-de-gard-cand-cumperi-o-crema-hidratanta-de-fata-greseli-si-tips" },
  { title: "Verdictul final: Ce crema hidratanta de fata cumpar eu daca dau azi o tura prin magazine", id: "verdictul-final-ce-crema-hidratanta-de-fata-cumpar-eu-daca-dau-azi-o-tura-prin-magazine" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

