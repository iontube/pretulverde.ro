import SimilarArticles from '../components/SimilarArticles.astro';
import keywordsData from '../../keywords.json';
import PrevNextNav from '../components/PrevNextNav.astro';

export const frontmatter = {
  title: "Cele mai bune aparate de aer conditionat",
  excerpt: "Daca ma intrebi pe mine, cele mai bune aparate de aer conditionat in 2024 sunt cele care iti ofera un echilibru bun intre performanta, eficienta energetica si pret. Asta inseamna de obicei modele inverter de la producatori consacrati precum Daikin, Gree, Midea sau LG. Pentru un confort garantat si facturi mai mici, cauta modele cu clasa energetica A++ sau A+++.",
  image: "/images/articles/cele-mai-bune-aparate-de-aer-conditionat.webp",
  category: "Electrocasnice",
  categorySlug: "electrocasnice",
  date: "2025-03-04T15:00:00.000Z",
  modifiedDate: "2026-02-21T14:50:31.603Z",
  author: "Andrei Ionescu",
  authorRole: "Expert Electrocasnice",
  authorBio: "Andrei testeaza si compara electrocasnice de peste 7 ani. Analizeaza raportul calitate-pret si performanta reala a fiecarui produs, de la masini de spalat la aspiratoare robot."
};

const breadcrumbs = [
  { name: "Acasa", url: "/" },
  { name: "Electrocasnice", url: "/electrocasnice/" },
  { name: "Cele mai bune aparate de aer conditionat", url: "/cele-mai-bune-aparate-de-aer-conditionat/" }
];

const faq = [
  { question: "cat costa un aparat de aer conditionat bun", answer: "Un aparat de aer conditionat bun, cu tehnologie inverter si clasa energetica A++ sau A+++, costa incepand de la aproximativ 2000 lei pentru un model de 12000 BTU. Modelele premium de la branduri recunoscute pot ajunge si la 3500-4500 lei sau chiar mai mult." },
  { question: "care e diferenta intre aer conditionat inverter si non-inverter", answer: "Aparatele cu inverter isi ajusteaza continuu turatia compresorului, oferind o temperatura constanta, un consum energetic mai mic (cu pana la 30-40%) si un nivel de zgomot redus. Cele non-inverter pornesc si se opresc brusc, fiind mai putin eficiente, mai zgomotoase si cu o temperatura mai fluctuanta." },
  { question: "ce aparat de aer conditionat e cel mai fiabil", answer: "Din experienta si parerile utilizatorilor, Daikin este considerat printre cele mai fiabile marci de aparate de aer conditionat, urmat de Fujitsu, Mitsubishi Electric si Panasonic. Aceste branduri investesc mult in calitate si tehnologie, rezultand o durata de viata mai lunga." },
  { question: "cat de des trebuie curatat aerul conditionat", answer: "Pentru o functionare optima si aer curat, filtrele interioare ale aparatului de aer conditionat trebuie curatate cel putin o data pe luna in sezonul de utilizare intensa. Curatarea completa a sistemului, inclusiv a unitatii exterioare, este recomandata o data pe an." },
  { question: "ce inseamna 12000 btu", answer: "BTU (British Thermal Unit) este unitatea de masura pentru capacitatea de racire sau incalzire. 12000 BTU este potrivit pentru spatii de aproximativ 15-25 metri patrati, in functie de izolatie, inaltime si expunerea la soare. Pentru camere mai mari sau mai mici, este necesara o alta capacitate." },
  { question: "ce clasa energetica e buna la aer conditionat", answer: "La aparatele de aer conditionat, clasa energetica A+++ este cea mai eficienta si economica, urmata de A++ si A+. In general, modelele cu clasa A++ sau A+++ sunt recomandate pentru un consum redus de energie electrica pe termen lung, chiar daca pretul initial poate fi mai ridicat." },
  { question: "unde gasesc cele mai bune preturi la aparate de aer conditionat", answer: "Cele mai bune preturi la aparate de aer conditionat se gasesc de obicei in magazinele mari de electronice (domestice si online) precum eMAG, Altex, Media Galaxy, sau magazine specializate in climatizare. Este indicat sa comparati ofertele si sa asteptati perioadele de reduceri (primavara, Black Friday)." },
  { question: "de ce nu mai porneste aerul conditionat", answer: "Daca aerul conditionat nu mai porneste, motivele pot fi diverse: lipsa curentului electric, o problema la telecomanda (baterii slabe, defecte), declansarea sigurantei automate, sau o defectiune interna a aparatului. Primul pas este verificarea alimentarii cu energie si a telecomenzii." }
];

const toc = [
  { title: "Alegerea Top Cele Mai Bune Aparate de Aer Conditionat Pe Bune", id: "alegerea-top-cele-mai-bune-aparate-de-aer-conditionat-pe-bune" },
  { title: "Top Recomandari: Cele Mai Bune Aparate de Aer Conditionat Cu Plusuri Si Minusuri", id: "top-recomandari-cele-mai-bune-aparate-de-aer-conditionat-cu-plusuri-si-minusuri" },
  { title: "Cum Alegi Cele Mai Bune Aparate de Aer Conditionat Pentru Tine", id: "cum-alegi-cele-mai-bune-aparate-de-aer-conditionat-pentru-tine" },
  { title: "Comparatie: Daikin vs. Gree - Ce Alegi?", id: "comparatie-daikin-vs-gree---ce-alegi" },
  { title: "Greșeli de Evitat: Ce Nu Vrei Să Faci Când Cumperi Cele Mai Bune Aparate de Aer Conditionat", id: "greseli-de-evitat-ce-nu-vrei-sa-faci-cand-cumperi-cele-mai-bune-aparate-de-aer-conditionat" },
  { title: "Verdict pe Bugete: Cele Mai Bune Aparate de Aer Conditionat", id: "verdict-pe-bugete-cele-mai-bune-aparate-de-aer-conditionat" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

