  { title: "Top 4 masini de gaurit si insurubat de incredere acum", id: "top-4-masini-de-gaurit-si-insurubat-de-incredere-acum" },
  { title: "Ce criterii conteaza cu adevarat la o bormasina pentru casa?", id: "ce-criterii-conteaza-cu-adevarat-la-o-bormasina-pentru-casa" },
