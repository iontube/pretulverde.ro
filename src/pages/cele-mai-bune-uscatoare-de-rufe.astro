      </ol>
    </nav>

    <!-- Title -->
    <h1 class="article-page-title">Cele mai bune uscatoare de rufe</h1>

    <!-- Meta -->
    <div class="article-page-meta">
      <span>Andrei Ionescu</span>
      <span>&middot;</span>
      <span>Publicat: 1 mai 2025</span>
      <span>&middot;</span>
      <span>Actualizat: 4 martie 2026</span>
    </div>

    <!-- Featured Image -->
    <img src="/images/articles/cele-mai-bune-uscatoare-de-rufe.webp" alt="Cele mai bune uscatoare de rufe" class="article-page-image" width="800" height="600" loading="eager">

    <!-- Two-column layout: content + TOC sidebar on RIGHT -->
    <div class="article-layout">
      <div>
        <!-- Mobile TOC (expandable) -->
        <div class="toc-mobile" id="toc-mobile">
          <button class="toc-mobile-toggle" onclick="this.parentElement.classList.toggle('open')">
            Cuprins
            <span class="toc-chevron">&#9660;</span>
          </button>
