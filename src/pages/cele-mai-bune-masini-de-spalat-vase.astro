};

const breadcrumbs = [
  { name: "Acasa", url: "/" },
  { name: "Electrocasnice", url: "/electrocasnice/" },
  { name: "Cele mai bune masini de spalat vase", url: "/cele-mai-bune-masini-de-spalat-vase/" }
];

const faq = [
  { question: "cat costa o masina de spalat vase buna?", answer: "O masina de spalat vase buna, cu eficienta energetica A++ si nivel de zgomot scazut, costa in general intre 1700 si 2500 lei. Modelele premium, cu tehnologii avansate de uscare si materiale superioare, pot ajunge si la 3000-3500 lei." },
  { question: "care e diferenta intre masina de spalat vase slim si una standard?", answer: "Masinile slim au o latime de 45 cm si o capacitate de 9-10 seturi, fiind ideale pentru spatii mici. Masinile standard au 60 cm latime si o capacitate de 12-14 seturi, potrivite pentru familii mai mari sau cei care gatesc des." },
  { question: "merita sa iau masina de spalat vase cu clasa energetica A+++?", answer: "Absolut. Desi pretul initial este mai mare, o masina A+++ consuma semnificativ mai putina energie si apa pe termen lung. Pe durata de viata a aparatului, economiile la facturi pot acoperi diferenta de pret." },
  { question: "ce masina de spalat vase e mai buna pentru familii mari?", answer: "Pentru familii mari, recomandam masinile de spalat vase cu o capacitate de minim 14 seturi. Acestea permit spalarea unei cantitati mai mari de vase dintr-o singura incarcare, economisind timp si resurse." },
  { question: "de ce nu usuca bine vasele masina mea de spalat vase?", answer: "Daca vasele raman umede, probabil masina ta nu are o tehnologie de uscare avansata (ex. zeolit, ventilatie). La modelele mai ieftine, uscarea se bazeaza doar pe caldura reziduala, care nu este intotdeauna suficienta, mai ales pentru plasticuri." },
  { question: "cum sa intretin masina de spalat vase ca sa tina mult?", answer: "Curata regulat filtrele, bratele de stropire si garniturile. Foloseste solutie speciala pentru curatarea masinii o data la 2-3 luni si verifica nivelul de sare si detergent de clatire. Nu supraaglomera masina." },
  { question: "cum recunosc o masina de spalat vase originala?", answer: "Cumpara doar din magazine autorizate, fizice sau online. Verifica daca produsul are garantie oficiala de la producator si daca documentatia este in limba romana. Evita ofertele suspect de ieftine de pe site-uri necunoscute." },
  { question: "unde gasesc cele mai bune preturi la masini de spalat vase?", answer: "Cele mai bune preturi la masini de spalat vase se gasesc de obicei in magazinele online mari de electronice si electrocasnice, mai ales in perioadele de reduceri (Black Friday, reduceri de sezon). Compara ofertele pe site-uri de comparare de preturi." }
];

const toc = [
  { title: "Alegerea Ta De Top: Cele Mai Bune Masini De Spalat Vase", id: "alegerea-ta-de-top-cele-mai-bune-masini-de-spalat-vase" },
  { title: "Top Recomandari: Masini De Spalat Vase Cu Preturi Si Minusuri Sincere", id: "top-recomandari-masini-de-spalat-vase-cu-preturi-si-minusuri-sincere" },
  { title: "Cum Alegi CEA Mai Buna Masina De Spalat Vase Pentru Tine: Ghidul Prietenului", id: "cum-alegi-cea-mai-buna-masina-de-spalat-vase-pentru-tine-ghidul-prietenului" },
  { title: "Comparatie: Brandul A vs. Brandul B - Cine Spala Mai Bine?", id: "comparatie-brandul-a-vs-brandul-b---cine-spala-mai-bine" },
  { title: "Greseli De Evitat Cand Cumperi O Masina De Spalat Vase", id: "greseli-de-evitat-cand-cumperi-o-masina-de-spalat-vase" },
  { title: "Recomandari Finale Pe Bugete: Ce Masina De Spalat Vase Merita", id: "recomandari-finale-pe-bugete-ce-masina-de-spalat-vase-merita" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

