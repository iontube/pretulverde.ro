    <!-- Featured Image -->
    <img src="/images/articles/cele-mai-bune-cuptoare-cu-microunde.webp" alt="Cele mai bune cuptoare cu microunde" class="article-page-image" width="800" height="600" loading="eager">

    <!-- Two-column layout: content + TOC sidebar on RIGHT -->
