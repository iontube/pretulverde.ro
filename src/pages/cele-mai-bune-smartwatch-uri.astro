};

const breadcrumbs = [
  { name: "Acasa", url: "/" },
  { name: "Telefoane si Laptopuri", url: "/telefoane-laptopuri/" },
  { name: "Cele mai bune smartwatch-uri", url: "/cele-mai-bune-smartwatch-uri/" }
];

const faq = [
  { question: "cat costa un smartwatch bun?", answer: "Un smartwatch bun, care sa ofere o experienta completa, costa intre 1500 si 2500 de lei. Modelele de top de la Apple sau Samsung pot ajunge si la 2800 de lei. Exista si optiuni decente sub 1000 de lei, cum ar fi cele de la Amazfit, ideale pentru nevoi de baza." },
  { question: "care e diferenta intre apple watch si samsung smartwatch?", answer: "Principala diferenta este compatibilitatea: Apple Watch functioneaza doar cu iPhone, iar Samsung Smartwatch (Galaxy Watch) functioneaza cel mai bine cu telefoane Android, dar se poate conecta si la iPhone, cu functionalitati limitate. Apple Watch are un ecosistem de aplicatii mai bogat, iar Samsung se lauda cu senzori de sanatate mai variati." },
  { question: "merita sa cumpar un smartwatch ieftin?", answer: "Merita daca ai nevoi simple: sa vezi notificari, sa monitorizezi pasii si pulsul, si vrei autonomie mare. Modelele ieftine, sub 800 de lei, de la branduri ca Amazfit sau Xiaomi, ofera un raport bun calitate-pret. Nu te astepta la aplicatii complexe sau la precizie medicala." },
  { question: "ce smartwatch e mai bun pentru sport?", answer: "Pentru sportivi seriosi, Garmin este cea mai buna optiune, cu modele precum Forerunner sau Fenix, care au GPS precis, autonomie mare si functii dedicate pentru diverse discipline. Apple Watch si Samsung Galaxy Watch sunt de asemenea bune pentru fitness, dar nu la fel de specializate." },
  { question: "de ce nu tine bateria la smartwatch?", answer: "Bateria la smartwatch tine putin din cauza ecranului luminos, a procesorului puternic si a senzorilor care functioneaza constant (GPS, puls, etc.). Modelele cu ecrane mai simple (non-AMOLED) sau cu baterii mai mari, cum ar fi cele de la Garmin sau Amazfit, pot tine chiar si 2-3 saptamani." },
  { question: "cum sa aleg smartwatch-ul potrivit", answer: "Alege in functie de telefonul tau (iPhone sau Android), buget, nevoile de utilizare (sport, sanatate, notificari), autonomia dorita si design. Citeste review-uri si compara specificatiile modelelor care te intereseaza." },
  { question: "ce probleme pot avea smartwatch-urile?", answer: "Cele mai frecvente probleme sunt autonomia redusa a bateriei, precizia inconsistenta a senzorilor (mai ales la modelele ieftine), compatibilitatea limitata cu anumite telefoane si, ocazional, blocaje software. Unele modele pot fi si mai putin rezistente la apa sau socuri." },
  { question: "unde gasesc cele mai bune preturi la smartwatch-uri?", answer: "Gasesti cele mai bune preturi la smartwatch-uri in magazinele online mari din Romania, cum ar fi eMAG, Altex, Flanco, PC Garage. Urmareste perioadele de reduceri (Black Friday, reduceri de sezon) si compara ofertele intre mai multe magazine pentru a gasi cea mai buna varianta." }
];

const toc = [
  { title: "Uite care sunt cele mai bune smartwatch-uri daca vrei ceva pe bune", id: "uite-care-sunt-cele-mai-bune-smartwatch-uri-daca-vrei-ceva-pe-bune" },
  { title: "Top 4 smartwatch-uri pe care sa le iei in calcul (cu bune si rele)", id: "top-4-smartwatch-uri-pe-care-sa-le-iei-in-calcul-cu-bune-si-rele" },
  { title: "Cum sa alegi smartwatch-ul potrivit fara sa te complici", id: "cum-sa-alegi-smartwatch-ul-potrivit-fara-sa-te-complici" },
  { title: "Apple Watch Series 9 vs. Samsung Galaxy Watch 6: Cine e regele? ", id: "apple-watch-series-9-vs-samsung-galaxy-watch-6-cine-e-regele-" },
  { title: "Greșeli pe care le fac toți când își iau smartwatch (și cum să le eviți)", id: "greseli-pe-care-le-fac-toti-cand-isi-iau-smartwatch-si-cum-sa-le-eviti" },
  { title: "Cel mai bun smartwatch pe bugetul tău: de la ieftin și bun, la premium", id: "cel-mai-bun-smartwatch-pe-bugetul-tau-de-la-ieftin-si-bun-la-premium" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

