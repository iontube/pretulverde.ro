  { title: "Cum sa-ti alegi bicicleta electrica potrivita: Ghidul prietenului tau", id: "cum-sa-ti-alegi-bicicleta-electrica-potrivita-ghidul-prietenului-tau" },
  { title: "Oras vs. Munte: Ce bicicleta electrica e mai buna pentru tine?", id: "oras-vs-munte-ce-bicicleta-electrica-e-mai-buna-pentru-tine" },
