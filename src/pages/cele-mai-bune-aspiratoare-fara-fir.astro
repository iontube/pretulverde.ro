          <article class="product-review" id="philips-speedpro-max-aqua">
            <div class="product-review__header">
              <span class="section-tag">Pentru Buget Mic</span>
              <h3>Philips SpeedPro Max Aqua</h3>
              <div class="product-review__specs-grid">
              <div class="product-review__spec">
                <strong>Tip</strong>aspirator vertical fara fir
              </div>
              <div class="product-review__spec">
                <strong>Brand</strong>Philips
              </div>
              <div class="product-review__spec">
                <strong>Specificatii cheie</strong>Motor Digital Inverter, pana la 60 minute autonomie (in mod Eco), sistem de aspirare si stergere integrat (Aqua), perie PowerBlade, filtrare 99.9% praf fin, lumini LED pe perie
              </div>
