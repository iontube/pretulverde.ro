const faq = [
  { question: "cat costa un aspirator robot bun?", answer: "Un aspirator robot bun, care sa faca treaba eficient si sa aiba navigatie inteligenta, costa intre 1500 si 2500 lei. Modelele de top, cu statie de auto-golire si functii avansate, pot ajunge si la 3000-4000 lei." },
  { question: "ce aspirator robot sa aleg pentru par de caine?", answer: "Pentru par de caine, cauta un aspirator robot cu putere mare de aspirare (minim 3000 Pa) si o perie principala eficienta, care sa nu se incurce usor. Modelele iRobot Roomba sau Roborock sunt recomandate, iar cele cu statie de auto-golire sunt un avantaj mare." },
  { question: "aspirator robot cu mop vs fara mop?", answer: "Daca ai predominant podele dure (gresie, parchet), un aspirator robot cu mop e util pentru o curatenie mai completa. Cauta modele cu mopuri active (vibratii sau rotatie) pentru rezultate mai bune, nu doar un lavetar tras dupa el." },
  { question: "cat rezista un aspirator robot?", answer: "Un aspirator robot de calitate, intretinut corespunzator, poate rezista intre 3 si 5 ani. Durata de viata a bateriei este de obicei de 1-2 ani, dupa care poate fi inlocuita." },
  { question: "aspirator robot xiaomi sau roborock?", answer: "Ambele branduri ofera modele bune. Roborock, in general, este considerat un pic superior la capitolul aspirare si functii de mop. Modelele Xiaomi sunt adesea mai accesibile si ofera un raport bun pret-calitate, mai ales pentru aspirare." },
  { question: "ce aspirator robot sa aleg pentru un apartament mic?", answer: "Pentru un apartament mic, nu ai nevoie de functii foarte avansate. Un model cu navigatie inteligenta (LiDAR sau vSLAM) si autonomie de cel putin 60-90 minute este suficient. Modelele de la Xiaomi sau Dreame din gama de mijloc sunt alegeri bune." },
  { question: "de ce nu se mai incarca aspiratorul robot?", answer: "Motivele frecvente sunt contactele murdare de pe baza de incarcare sau de pe robot, o baterie uzata, sau o problema cu alimentarea electrica. Curata contactele si verifica daca robotul este asezat corect pe statie." },
  { question: "cand merita sa cumpar un aspirator robot cu statie de auto-golire?", answer: "Merita sa cumperi un aspirator robot cu statie de auto-golire daca vrei sa uiti de golirea rezervorului pentru 3-4 saptamani, daca ai animale de companie care produc mult praf, sau daca ai un program foarte aglomerat si nu vrei sa te ocupi de intretinerea zilnica a robotului." }
];

const toc = [
  { title: "Cel mai bun aspirator robot pe care sa-l iei acum (fara sa dai faliment)", id: "cel-mai-bun-aspirator-robot-pe-care-sa-l-iei-acum-fara-sa-dai-faliment" },
  { title: "4 aspiratoare robot pe care sa le iei in calcul azi (cu plusuri si minusuri sincere)", id: "4-aspiratoare-robot-pe-care-sa-le-iei-in-calcul-azi-cu-plusuri-si-minusuri-sincere" },
  { title: "Ce conteaza cu adevarat la un aspirator robot (fara marketing prost)", id: "ce-conteaza-cu-adevarat-la-un-aspirator-robot-fara-marketing-prost" },
  { title: "Roomba j7+ vs Roborock S7: Care e alesul tau pe bune?", id: "roomba-j7-vs-roborock-s7-care-e-alesul-tau-pe-bune" },
  { title: "Ce greșeli mari faci cand cumperi aspirator robot (si cum sa le eviți)", id: "ce-greseli-mari-faci-cand-cumperi-aspirator-robot-si-cum-sa-le-eviti" },
  { title: "Verdictul final: Ce aspirator robot cumpar eu azi si de ce", id: "verdictul-final-ce-aspirator-robot-cumpar-eu-azi-si-de-ce" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

