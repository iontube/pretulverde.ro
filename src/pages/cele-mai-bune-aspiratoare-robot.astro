const breadcrumbs = [
  { name: "Acasa", url: "/" },
  { name: "Electrocasnice", url: "/electrocasnice/" },
  { name: "Cele mai bune aspiratoare robot", url: "/cele-mai-bune-aspiratoare-robot/" }
